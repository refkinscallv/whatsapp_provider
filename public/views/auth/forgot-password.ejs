<div class="card w-96 bg-base-100 shadow backdrop-blur-md">
    <div class="card-body">
        <h2 class="card-title text-2xl font-bold mb-2">Forgot Password</h2>
        <p class="text-gray-400 text-sm mb-4">Enter your email address and we'll send you a link to reset your password.
        </p>

        <form id="forgotPasswordForm">
            <div class="form-control w-full">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Email
                    Address</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-3 flex items-center text-gray-400">
                        <i class="ri-mail-line"></i>
                    </span>
                    <input type="email" name="email" placeholder="email@example.com"
                        class="input input-bordered w-full pl-10 text-base-content rounded-2xl" required />
                </div>
            </div>

            <div class="card-actions justify-end mt-6">
                <button type="submit" class="btn btn-primary w-full shadow-lg shadow-primary/20">
                    <span class="loading loading-spinner hidden" id="loading"></span>
                    Send Reset Link
                </button>
            </div>
        </form>

        <div class="mt-4 text-center">
            <p class="text-sm text-base-content/60">
                Remember your password? <a href="/login" class="text-primary hover:underline font-bold">Log in</a>
            </p>
        </div>
    </div>
</div>

<script>
    document.getElementById('forgotPasswordForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const btn = form.querySelector('button');
        const loading = document.getElementById('loading');

        btn.disabled = true;
        loading.classList.remove('hidden');

        try {
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());

            const res = await axios.post('/api/auth/forgot-password', data);

            showToast.success(res.data.message || 'Password reset link sent to your email', 'Check your email');

            form.reset();
        } catch (err) {
            showToast.error(err.response?.data?.message || 'Something went wrong', 'Error');
        } finally {
            btn.disabled = false;
            loading.classList.add('hidden');
        }
    });
</script>