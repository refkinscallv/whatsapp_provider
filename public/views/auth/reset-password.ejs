<div class="card w-96 bg-base-100 shadow-xl backdrop-blur-md">
    <div class="card-body">
        <h2 class="card-title text-2xl font-bold text-base-content mb-2">Reset Password</h2>
        <p class="text-base-content/70 text-sm mb-4">Enter your new password below.</p>

        <form id="resetPasswordForm">
            <input type="hidden" name="token" value="<%= token %>" />

            <div class="form-control w-full">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">New
                    Password</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-3 flex items-center text-base-content/70">
                        <i class="ri-lock-line"></i>
                    </span>
                    <input type="password" name="password" placeholder="••••••••"
                        class="input input-bordered w-full pl-10 text-base-content rounded-2xl" required
                        minlength="6" />
                </div>
            </div>

            <div class="form-control w-full mt-4">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Confirm
                    Password</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-3 flex items-center text-base-content/70">
                        <i class="ri-lock-check-line"></i>
                    </span>
                    <input type="password" name="confirm_password" placeholder="••••••••"
                        class="input input-bordered w-full pl-10 text-base-content rounded-2xl" required />
                </div>
            </div>

            <div class="card-actions justify-end mt-6">
                <button type="submit" class="btn btn-primary w-full shadow-lg shadow-primary/20">
                    <span class="loading loading-spinner hidden" id="loading"></span>
                    Reset Password
                </button>
            </div>
        </form>

        <div class="mt-4 text-center">
            <a href="/login" class="text-sm text-primary hover:underline">Back to Login</a>
        </div>
    </div>
</div>

<script>
    document.getElementById('resetPasswordForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const btn = form.querySelector('button');
        const loading = document.getElementById('loading');

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        if (data.password !== data.confirm_password) {
            showToast.error('Passwords do not match', 'Error');
            return;
        }

        btn.disabled = true;
        loading.classList.remove('hidden');

        try {
            const res = await axios.post('/api/auth/reset-password', {
                token: data.token,
                password: data.password
            });

            showToast.success(res.data.message || 'Password has been reset successfully', 'Success!');
            setTimeout(() => {
                window.location.href = '/login';
            }, 1500);
        } catch (err) {
            showToast.error(err.response?.data?.message || 'Something went wrong', 'Error');
        } finally {
            btn.disabled = false;
            loading.classList.add('hidden');
        }
    });
</script>