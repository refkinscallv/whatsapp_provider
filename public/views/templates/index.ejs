<div class="flex flex-col gap-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-base-content">Message Templates</h1>
            <p class="text-base-content/60">Save your common messages for quick use.</p>
        </div>
        <div>
            <button onclick="openTemplateModal()" class="btn btn-primary rounded-xl"><i class="ri-add-line"></i> Create
                Template</button>
        </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="template-grid">
        <p class="col-span-full text-center py-20 text-base-content/30 italic">No templates found.</p>
    </div>
</div>

<!-- Modal -->
<dialog id="modal_template" class="modal">
    <div class="modal-box bg-base-100 border border-base-content/50 rounded-3xl p-0 overflow-hidden">
        <div class="p-6 border-b border-base-content/50">
            <h3 class="font-bold text-xl text-base-content" id="modal-title">New Template</h3>
        </div>

        <input type="hidden" id="editToken" />

        <div class="p-6 space-y-6">
            <div class="form-control">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Template
                    Name</label>
                <input type="text" id="templateName" class="input input-bordered w-full text-base-content rounded-2xl"
                    placeholder="e.g. Welcome Message" />
            </div>
            <div class="form-control">
                <label class="flex justify-between items-center mb-2">
                    <span class="block uppercase text-[11px] font-semibold tracking-widest opacity-60">Content</span>
                    <span class="text-[10px] opacity-40 italic">Variables like {name} are supported.</span>
                </label>
                <textarea id="templateContent"
                    class="textarea textarea-bordered w-full text-base-content h-40 rounded-2xl"
                    placeholder="Hello {name}..."></textarea>
            </div>
        </div>

        <div class="modal-action p-6 border-t border-base-content/50 mt-0">
            <form method="dialog"><button class="btn btn-ghost rounded-xl">Cancel</button></form>
            <button onclick="saveTemplate()" class="btn btn-primary rounded-xl px-8">Save Template</button>
        </div>
    </div>
</dialog>

<script>
    async function loadTemplates() {
        try {
            const res = await axios.get('/api/templates');
            const grid = $('#template-grid');
            if (res.data.success && res.data.templates.length > 0) {
                grid.html(res.data.templates.map(t => `
                    <div class="card glass border border-base-content/10 group">
                        <div class="card-body">
                            <div class="flex justify-between items-start">
                                <h3 class="font-bold text-base-content">${t.name}</h3>
                                <div class="dropdown dropdown-end">
                                    <div tabindex="0" role="button" class="btn btn-ghost btn-xs rounded-lg"><i class="ri-more-2-fill"></i></div>
                                    <ul tabindex="0" class="dropdown-content z-[20] menu p-2 shadow-2xl bg-base-200 border border-base-content/10 rounded-xl w-32">
                                        <li><a onclick="editTemplate('${t.token}')"><i class="ri-edit-line"></i> Edit</a></li>
                                        <li><a onclick="deleteTemplate('${t.token}')" class="text-error"><i class="ri-delete-bin-line"></i> Delete</a></li>
                                    </ul>
                                </div>
                            </div>
                            <p class="text-xs text-base-content/60 mt-2 line-clamp-4 whitespace-pre-line">${t.content}</p>
                            <div class="flex justify-between items-center mt-4 pt-4 border-t border-base-content/50">
                                <div class="text-[9px] uppercase tracking-tighter opacity-40">Created by: ${t.user?.name || '-'}</div>
                                <a href="/messaging" class="btn btn-ghost btn-xs text-primary rounded-lg">Use in Chat</a>
                            </div>
                        </div>
                    </div>
                `).join(''));
            } else {
                grid.html('<p class="col-span-full text-center py-20 text-base-content/30 italic">No templates found.</p>');
            }
        } catch (err) { console.error(err); }
    }

    function openTemplateModal() {
        $('#modal-title').text('New Template');
        $('#editToken').val('');
        $('#templateName').val('');
        $('#templateContent').val('');
        $('#modal_template')[0].showModal();
    }

    async function editTemplate(token) {
        try {
            const res = await axios.get(`/api/templates/${token}`);
            const t = res.data.template;
            $('#modal-title').text('Edit Template');
            $('#editToken').val(token);
            $('#templateName').val(t.name);
            $('#templateContent').val(t.content);
            $('#modal_template')[0].showModal();
        } catch (err) { showToast.error('Failed to load template', 'Error'); }
    }

    async function saveTemplate() {
        const name = $('#templateName').val();
        const content = $('#templateContent').val();
        const token = $('#editToken').val();

        if (!name || !content) return;

        try {
            if (token) {
                await axios.put(`/api/templates/${token}`, { name, content });
            } else {
                await axios.post('/api/templates', { name, content });
            }
            $('#modal_template')[0].close();
            loadTemplates();
        } catch (err) { showToast.error('Failed to save template', 'Error'); }
    }

    async function deleteTemplate(token) {
        const confirmResult = await showConfirm(
            'Delete this template?',
            'This action cannot be undone.'
        );
        if (!confirmResult.isConfirmed) return;
        try {
            await axios.delete(`/api/templates/${token}`);
            loadTemplates();
        } catch (err) { showToast.error('Failed to delete template', 'Error'); }
    }

    $(document).ready(loadTemplates);
</script>