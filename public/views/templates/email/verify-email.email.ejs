<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>Verify Your Email - <%= appName %>
    </title>
    <style>
        body {
            font-family: sans-serif;
            line-height: 1.6;
            color: #333;
            padding: 20px;
            background-color: #f4f4f4;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            background: #fff;
            padding: 30px;
            border-radius: 10px;
        }

        .btn {
            display: inline-block;
            padding: 12px 24px;
            background-color: #25d366;
            color: #fff;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            margin-top: 20px;
        }
    </style>
</head>

<body>
    <div class="container">
        <h2>Verify Your Email</h2>
        <p>Hi <%= name %>,</p>
        <p>Thank you for registering! Please click the button below to verify your email address and activate your
            account.</p>
        <a href="<%= appUrl %>/verify-email?token=<%= token %>" class="btn">Verify Email</a>
        <p>Best regards,<br>The <%= appName %> Team</p>
    </div>
</body>

</html>