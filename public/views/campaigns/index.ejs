<div class="flex flex-col gap-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-base-content">Broadcast Campaigns</h1>
            <p class="text-base-content/60">Schedule and monitor bulk messaging campaigns.</p>
        </div>
        <div class="flex gap-2">
            <button onclick="DataTableHelper.openFilterModal('filter_modal_campaigns', 'campaigns-table')"
                class="btn btn-ghost glass btn-sm rounded-lg"><i class="ri-filter-3-line"></i> Filter</button>
            <button onclick="openCampaignModal()" class="btn btn-primary btn-sm rounded-lg"><i
                    class="ri-rocket-2-line"></i>
                Create Campaign</button>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card glass hover:border-primary/30 transition-all duration-300 group">
            <div class="card-body p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Active
                            Campaigns</p>
                        <h2 class="text-4xl font-black mt-2 text-base-content" id="stat-active">0</h2>
                    </div>
                    <div
                        class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                        <i class="ri-rocket-2-line text-2xl"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="card glass hover:border-success/30 transition-all duration-300 group">
            <div class="card-body p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Total Sent
                            (30d)</p>
                        <h2 class="text-4xl font-black mt-2 text-base-content" id="stat-sent">0</h2>
                    </div>
                    <div
                        class="w-14 h-14 bg-success/10 rounded-2xl flex items-center justify-center text-success group-hover:scale-110 transition-transform">
                        <i class="ri-send-plane-fill text-2xl"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="card glass hover:border-error/30 transition-all duration-300 group">
            <div class="card-body p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Total Failed
                            (30d)</p>
                        <h2 class="text-4xl font-black mt-2 text-base-content" id="stat-failed">0</h2>
                    </div>
                    <div
                        class="w-14 h-14 bg-error/10 rounded-2xl flex items-center justify-center text-error group-hover:scale-110 transition-transform">
                        <i class="ri-error-warning-fill text-2xl"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Campaigns List -->
    <div class="card glass">
        <div class="card-body">
            <h3 class="font-bold text-lg mb-4 text-base-content">Campaign List</h3>
            <div class="overflow-x-auto">
                <table id="campaigns-table" class="table table-zebra w-full">
                    <thead>
                        <tr
                            class="text-base-content/60 uppercase text-[10px] tracking-widest border-b-2 border-base-content/50">
                            <th>Campaign Name</th>
                            <th>Device</th>
                            <th class="text-center">Creator</th>
                            <th>Progress</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Data loaded via server-side DataTables -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Filter Modal for Campaigns -->
<dialog id="filter_modal_campaigns" class="modal">
    <div class="modal-box bg-base-100 border border-base-content/50 rounded-3xl max-w-md p-0 overflow-hidden">
        <div class="p-6 border-b border-base-content/50">
            <h3 class="font-bold text-xl text-base-content flex items-center gap-2">
                <i class="ri-filter-3-line text-primary"></i> Filter Campaigns
            </h3>
        </div>

        <form id="filter_form_campaigns" class="p-6 space-y-6">
            <!-- Source Device Filter -->
            <%- include('../layouts/partials/device_selector', { id: 'filter-device-token-camp' , name: 'device_token' ,
                label: 'Device' , showAllOption: true, extraClass: 'bg-base-200/50' }) %>

                <!-- Engine Filter -->
                <div class="form-control">
                    <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">WhatsApp
                        Engine</label>
                    <select name="provider" class="select select-bordered w-full rounded-2xl bg-base-200/50">
                        <option value="">All Engines</option>
                        <option value="wwebjs">WhatsApp-Web.js (WWebJS)</option>
                        <option value="baileys">Baileys (WebSockets)</option>
                    </select>
                </div>

                <!-- Status Filter -->
                <div class="form-control">
                    <label
                        class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Status</label>
                    <select name="status" class="select select-bordered w-full rounded-2xl bg-base-200/50">
                        <option value="">All Statuses</option>
                        <option value="running">Running</option>
                        <option value="completed">Completed</option>
                        <option value="paused">Paused</option>
                        <option value="failed">Failed</option>
                    </select>
                </div>

                <!-- Has Media Filter -->
                <div class="form-control">
                    <label
                        class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Attachment</label>
                    <select name="has_media" class="select select-bordered w-full rounded-2xl bg-base-200/50">
                        <option value="">All</option>
                        <option value="yes">Has Media</option>
                        <option value="no">No Media</option>
                    </select>
                </div>

                <!-- Date Range -->
                <div class="grid grid-cols-2 gap-4">
                    <div class="form-control">
                        <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">From
                            Date</label>
                        <input type="date" name="created_from"
                            class="input input-bordered w-full rounded-2xl bg-base-200/50">
                    </div>
                    <div class="form-control">
                        <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">To
                            Date</label>
                        <input type="date" name="created_to"
                            class="input input-bordered w-full rounded-2xl bg-base-200/50">
                    </div>
                </div>
        </form>

        <div class="modal-action p-6 border-t border-base-content/50 mt-0">
            <button type="button"
                onclick="DataTableHelper.resetFilters('filter_form_campaigns', 'campaigns-table', 'filter_modal_campaigns')"
                class="btn btn-ghost rounded-xl">
                <i class="ri-restart-line"></i> Reset
            </button>
            <button type="button" onclick="DataTableHelper.applyFilters('campaigns-table', 'filter_modal_campaigns')"
                class="btn btn-primary rounded-xl px-8">
                <i class="ri-check-line"></i> Apply Filter
            </button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>


<!-- Modal -->
<dialog id="modal_campaign" class="modal">
    <div class="modal-box bg-base-100 border border-base-content/50 max-w-2xl">
        <h3 class="font-bold text-lg mb-6 text-base-content">New Broadcast Campaign</h3>

        <form id="campaignForm" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <%- include('../layouts/partials/device_selector', { id: 'campDevice' , label: 'Select Device' ,
                    required: true }) %>
                    <div class="form-control">
                        <label
                            class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Campaign
                            Name</label>
                        <input type="text" id="campName"
                            class="input input-bordered w-full text-base-content rounded-2xl"
                            placeholder="e.g. Feb Promo" required />
                    </div>
            </div>

            <div class="form-control">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Target
                    Type</label>
                <div class="flex gap-2">
                    <input type="radio" name="targetType" value="book" class="btn btn-sm btn-outline rounded-lg flex-1"
                        aria-label="Contact Book" checked onchange="toggleTargetType('book')" />
                    <input type="radio" name="targetType" value="manual"
                        class="btn btn-sm btn-outline rounded-lg flex-1" aria-label="Manual / Select"
                        onchange="toggleTargetType('manual')" />
                </div>
            </div>

            <div id="target-book-container" class="form-control">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Select Target
                    Book</label>
                <select id="campBook" class="select select-bordered w-full rounded-2xl"></select>
            </div>

            <div id="target-manual-container" class="form-control hidden">
                <label class="flex justify-between items-center mb-2">
                    <div class="flex items-center gap-2">
                        <span class="block uppercase text-[11px] font-semibold tracking-widest opacity-60">Recipient
                            Numbers</span>
                        <button type="button" onclick="openContactModal('#campReceivers')"
                            class="btn btn-ghost btn-xs text-primary gap-1">
                            <i class="ri-contacts-book-line"></i> Select
                        </button>
                    </div>
                </label>
                <textarea id="campReceivers"
                    class="textarea textarea-bordered w-full h-24 rounded-2xl font-mono text-sm"
                    placeholder="62812...\n62856..."></textarea>
            </div>

            <div class="form-control">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Message
                    Template / Content</label>
                <select id="campTemplate" class="select select-bordered w-full rounded-2xl">
                    <option value="">Manual Entry (type below)</option>
                </select>
                <textarea id="campMessage" class="textarea textarea-bordered w-full h-32 rounded-2xl mt-4"
                    placeholder="Message content..."></textarea>
            </div>

            <div class="form-control">
                <label
                    class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60 text-primary">Attachment
                    (Image)</label>
                <div class="flex flex-col gap-4">
                    <input type="file" id="campFile"
                        class="file-input file-input-bordered file-input-primary w-full rounded-2xl" accept="image/*"
                        onchange="previewImage(this, 'campPreview')" />
                    <div id="campPreview" class="hidden">
                        <div class="relative w-full max-w-xs rounded-2xl overflow-hidden shadow-lg group">
                            <img src="" class="w-full h-auto object-contain" />
                            <button type="button" onclick="removePreview('campFile', 'campPreview')"
                                class="absolute top-2 right-2 btn btn-circle btn-xs btn-error opacity-0 group-hover:opacity-100 transition-opacity">
                                <i class="ri-close-line"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="form-control">
                    <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Min Delay
                        (sec)</label>
                    <input type="number" id="campMinDelay"
                        class="input input-bordered w-full text-base-content rounded-2xl" value="2" />
                </div>
                <div class="form-control">
                    <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Max Delay
                        (sec)</label>
                    <input type="number" id="campMaxDelay"
                        class="input input-bordered w-full text-base-content rounded-2xl" value="5" />
                </div>
            </div>

            <div class="modal-action">
                <form method="dialog"><button class="btn btn-ghost">Cancel</button></form>
                <button type="submit" class="btn btn-primary rounded-xl px-10">Launch Campaign</button>
            </div>
        </form>
    </div>
</dialog>

<!-- Campaign Detail Modal -->
<dialog id="modal_campaign_detail" class="modal">
    <div
        class="modal-box w-11/12 max-w-4xl bg-base-100 rounded-3xl border border-base-content/50 shadow-2xl p-0 overflow-hidden">
        <div class="p-6 flex justify-between items-center">
            <div class="flex items-center gap-4">
                <div class="p-3 bg-white/20 rounded-2xl">
                    <i class="ri-broadcast-line text-2xl"></i>
                </div>
                <div>
                    <h3 class="font-bold text-xl mb-0.5" id="detailTitle">Campaign Detail</h3>
                    <p class="text-xs opacity-80" id="detailToken"></p>
                </div>
            </div>
            <form method="dialog">
                <button class="btn btn-sm btn-circle btn-ghost"><i class="ri-close-line"></i></button>
            </form>
        </div>

        <div class="p-8">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Left Column: Info & Message -->
                <div class="lg:col-span-2 space-y-6">
                    <div class="bg-base-200/30 rounded-3xl p-6 border border-base-content/50">
                        <label class="block mb-3 uppercase text-[11px] font-bold tracking-widest opacity-60">Message
                            Content</label>
                        <div id="detailMessage"
                            class="whitespace-pre-wrap text-sm leading-relaxed p-4 bg-base-100 rounded-2xl border border-base-content/50 min-h-[100px]">
                        </div>

                        <div id="detailMedia" class="mt-4 hidden">
                            <label
                                class="block mb-2 uppercase text-[10px] font-bold tracking-widest opacity-40">Attached
                                Media</label>
                            <img id="detailMediaImg" src=""
                                class="max-h-[200px] rounded-2xl border border-base-content/10 cursor-pointer hover:opacity-90 transition-opacity"
                                onclick="window.open(this.src, '_blank')" />
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-6">
                        <div class="bg-base-200/30 rounded-3xl p-6 border border-base-content/50">
                            <label
                                class="block mb-2 uppercase text-[11px] font-bold tracking-widest opacity-60">Schedule</label>
                            <div class="flex items-center gap-3">
                                <i class="ri-calendar-event-line text-primary"></i>
                                <span id="detailSchedule" class="font-semibold">-</span>
                            </div>
                        </div>
                        <div class="bg-base-200/30 rounded-3xl p-6 border border-base-content/50">
                            <label
                                class="block mb-2 uppercase text-[11px] font-bold tracking-widest opacity-60">Delays</label>
                            <div class="flex items-center gap-3">
                                <i class="ri-hourglass-2-line text-primary"></i>
                                <span id="detailDelay" class="font-semibold">-</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Stats & Actions -->
                <div class="space-y-6">
                    <div class="bg-base-200/30 rounded-3xl p-6 border border-base-content/50">
                        <label
                            class="block mb-4 uppercase text-[11px] font-bold tracking-widest opacity-60">Results</label>
                        <div class="space-y-4">
                            <div class="flex justify-between items-center">
                                <span class="text-sm opacity-70">Total Recipients</span>
                                <span id="detailTotal" class="font-bold">-</span>
                            </div>
                            <div class="flex justify-between items-center text-success">
                                <span class="text-sm">Sent Successfully</span>
                                <span id="detailSent" class="font-bold">-</span>
                            </div>
                            <div class="flex justify-between items-center text-error">
                                <span class="text-sm">Failed</span>
                                <span id="detailFailed" class="font-bold">-</span>
                            </div>
                        </div>

                        <div class="mt-6">
                            <progress id="detailProgress" class="progress progress-primary w-full h-3" value="0"
                                max="100"></progress>
                            <div class="flex justify-between mt-2">
                                <span class="text-[10px] font-bold opacity-40 uppercase tracking-wider">Progress</span>
                                <span id="detailPercent" class="text-[10px] font-bold text-primary">0%</span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-base-200/30 rounded-3xl p-6 border border-base-content/50">
                        <label class="block mb-3 uppercase text-[11px] font-bold tracking-widest opacity-60">Device &
                            Status</label>
                        <div class="space-y-3">
                            <div
                                class="flex items-center gap-3 bg-base-100 p-3 rounded-2xl border border-base-content/50">
                                <div
                                    class="w-8 h-8 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                                    <i class="ri-smartphone-line"></i>
                                </div>
                                <div class="flex flex-col">
                                    <span class="text-xs font-bold" id="detailDevice">-</span>
                                    <span class="text-[9px] opacity-50 uppercase tracking-tighter"
                                        id="detailDeviceToken">-</span>
                                </div>
                            </div>
                            <div class="flex items-center justify-center p-2">
                                <span id="detailStatus"
                                    class="badge badge-lg py-4 px-6 uppercase text-xs font-black tracking-widest font-bold">-</span>
                            </div>
