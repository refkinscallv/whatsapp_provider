        <div class="bg-base-200/50 p-6 flex justify-end gap-3 px-8">
            <form method="dialog">
                <button class="btn btn-ghost rounded-2xl border-base-content/10 px-8">Close</button>
            </form>
        </div>
    </div>
</dialog>

<script>
    async function initCampaigns() {
        loadCampaigns();
        loadStats();
        loadFormData();
        setupRealtimeUpdates();
    }

    async function loadStats() {
        try {
            const res = await axios.get('/api/campaigns/stats');
            if (res.data.success) {
                const s = res.data.stats;
                document.getElementById('stat-active').innerText = s.active || 0;
                document.getElementById('stat-sent').innerText = s.sent_30d || 0;
                document.getElementById('stat-failed').innerText = s.failed_30d || 0;
            }
        } catch (err) {
            console.error('Failed to load campaign stats:', err);
        }
    }

    let campaignDataTable = null;

    async function loadCampaigns() {
        if (campaignDataTable) {
            campaignDataTable.ajax.reload(null, false);
            return;
        }

        // Initialize server-side DataTable
        const columns = [
            {
                data: 'name',
                render: (data, type, row) => `
                    <div class="flex items-center gap-3">
                        ${row.media_url ? `
                            <div class="avatar">
                                <div class="w-10 h-10 rounded-lg">
                                    <img src="${row.media_url}" class="object-cover" onclick="window.open('${row.media_url}', '_blank')" />
                                </div>
                            </div>
                        ` : ''}
                        <div class="flex flex-col">
                            <span class="font-bold text-base-content">${data}</span>
                            <span class="text-[10px] text-base-content/40">${row.token.substring(0, 16)}...</span>
                        </div>
                    </div>
                `
            },
            {
                data: 'device_token',
                render: (data, type, row) => `
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-base-content/80 font-semibold">${row.device ? row.device.name : (data ? data.substring(0, 8) + '...' : '-')}</span>
                    </div>
                `
            },
            {
                data: 'user.name',
                className: 'text-center',
                render: (data) => `<div class="badge badge-ghost badge-sm font-semibold opacity-70">${data || '-'}</div>`
            },
            {
                data: 'sent_count',
                className: 'min-w-[200px]',
                render: (data, type, row) => `
                    <div class="flex flex-col gap-1">
                        <div class="flex items-center gap-2">
                            <progress class="progress progress-primary w-full h-2" value="${data + row.failed_count}" max="${row.total_recipients}"></progress>
                            <span class="text-[10px] font-mono whitespace-nowrap text-base-content/60 font-bold campaign-progress-text">${data}/${row.total_recipients}</span>
                        </div>
                        ${row.failed_count > 0 ? `<span class="text-[9px] text-error/60"><i class="ri-error-warning-line"></i> ${row.failed_count} failed</span>` : ''}
                    </div>
                `
            },
            {
                data: 'status',
                render: (data) => `<span class="badge ${getStatusBadge(data)} badge-sm uppercase text-[10px] font-bold campaign-status-badge">${data}</span>`
            },
            {
                data: 'createdAt',
                render: (data) => `
                    <div class="flex flex-col text-xs text-base-content/60">
                        <span>${new Date(data).toLocaleDateString()}</span>
                        <span class="text-[10px] opacity-50">${new Date(data).toLocaleTimeString()}</span>
                    </div>
                `
            },
            {
                data: 'token',
                className: 'text-center',
                orderable: false,
                render: (data) => `
                    <div class="flex items-center gap-1">
                        <button onclick="showCampaignDetail('${data}')" class="btn btn-ghost btn-xs text-primary hover:bg-primary/10">
                            <i class="ri-eye-line"></i>
                        </button>
                        <button onclick="deleteCampaign('${data}')" class="btn btn-ghost btn-xs text-error hover:bg-error/10">
                            <i class="ri-delete-bin-line"></i>
                        </button>
                    </div>
                `
            }
        ];

        campaignDataTable = DataTableHelper.init('campaigns-table', '/api/datatable/campaigns', columns, {
            order: [[5, 'desc']],
            pageLength: 10,
            filterFormId: 'filter_form_campaigns',
            createdRow: (row, data) => {
                $(row).attr('data-campaign-token', data.token);
            }
        });
    }

    function setupRealtimeUpdates() {
        if (typeof io === 'undefined') {
            console.warn('Socket.IO not available');
            return;
        }

        // Get user token from page context
        const uToken = '<%= userToken %>';

        const socket = io({
            query: {
                userToken: uToken
            }
        });

        socket.on('connect', () => {
            // Socket connected
        });

        socket.on('campaign:update', (data) => {
            // Update specific row
            updateCampaignRow(data);
            // Update stats
            loadStats();
        });

        socket.on('disconnect', () => {
            // Socket disconnected
        });
    }

    function updateCampaignRow(data) {
        if (!campaignDataTable) {
            // If DataTable not initialized, do full reload
            loadCampaigns();
            return;
        }

        // Find row by data attribute
        const row = document.querySelector(`tr[data-campaign-token="${data.token}"]`);
        if (!row) {
            console.warn('Campaign row not found:', data.token);
            return;
        }

        // Update progress bar and text
        const progressBar = row.querySelector('progress');
        const progressText = row.querySelector('.campaign-progress-text');
        const statusBadge = row.querySelector('.campaign-status-badge');

        if (progressBar && progressText) {
            const currentProgress = data.sent_count + data.failed_count;
            progressBar.value = currentProgress;
            progressBar.max = data.total_recipients;
            progressText.textContent = `${data.sent_count}/${data.total_recipients}`;

            // Add smooth animation
            progressBar.classList.add('transition-all', 'duration-300');
        }

        // Update status badge
        if (statusBadge) {
            statusBadge.className = `badge ${getStatusBadge(data.status)} badge-sm uppercase text-[10px] font-bold campaign-status-badge`;
            statusBadge.textContent = data.status.toUpperCase();
        }

        // Update failed count if exists
        const progressContainer = row.querySelector('td:nth-child(3) > div');
        if (progressContainer && data.failed_count > 0) {
            let failedSpan = progressContainer.querySelector('.text-error\\/60');
            if (!failedSpan) {
                failedSpan = document.createElement('span');
                failedSpan.className = 'text-[9px] text-error/60';
                progressContainer.appendChild(failedSpan);
            }
            failedSpan.innerHTML = `<i class="ri-error-warning-line"></i> ${data.failed_count} failed`;
        }
    }

    function getStatusBadge(status) {
        if (status === 'completed') return 'badge-success';
        if (status === 'running') return 'badge-warning';
        if (status === 'paused') return 'badge-ghost';
        if (status === 'failed' || status === 'cancelled') return 'badge-error';
        return 'badge-primary';
    }

    async function showCampaignDetail(token) {
        try {
            const response = await fetch(`/api/campaigns/${token}`);
            const result = await response.json();

            if (!result.success) {
                showToast.error(result.message || 'Failed to load campaign detail');
                return;
            }

            const campaign = result.campaign;

            // Fill modal data
            document.getElementById('detailTitle').textContent = campaign.name;
            document.getElementById('detailToken').textContent = campaign.token;
            document.getElementById('detailMessage').textContent = campaign.message;

            if (campaign.media_url) {
                document.getElementById('detailMedia').classList.remove('hidden');
                document.getElementById('detailMediaImg').src = campaign.media_url;
            } else {
                document.getElementById('detailMedia').classList.add('hidden');
            }

            document.getElementById('detailSchedule').textContent = campaign.scheduled_at ?
                new Date(campaign.scheduled_at).toLocaleString() : 'As soon as possible';

            // Extract delays from metadata if available
            const minDelay = campaign.metadata?.min_delay || '-';
            const maxDelay = campaign.metadata?.max_delay || '-';
            document.getElementById('detailDelay').textContent = `${minDelay}s - ${maxDelay}s`;

            document.getElementById('detailTotal').textContent = campaign.total_recipients;
            document.getElementById('detailSent').textContent = campaign.sent_count;
            document.getElementById('detailFailed').textContent = campaign.failed_count;

            const progress = campaign.sent_count + campaign.failed_count;
            const percent = Math.round((progress / campaign.total_recipients) * 100) || 0;

            document.getElementById('detailProgress').value = progress;
            document.getElementById('detailProgress').max = campaign.total_recipients;
            document.getElementById('detailPercent').textContent = `${percent}%`;

            document.getElementById('detailDevice').textContent = campaign.device?.name || 'Unknown Device';
            document.getElementById('detailDeviceToken').textContent = campaign.device_token;

            const statusBadge = document.getElementById('detailStatus');
            statusBadge.className = `badge badge-lg py-4 px-6 uppercase text-xs font-black tracking-widest ${getStatusBadge(campaign.status)}`;
            statusBadge.textContent = campaign.status;

            modal_campaign_detail.showModal();
        } catch (err) {
            console.error('Error loading campaign detail:', err);
            showToast.error('An unexpected error occurred');
        }
    }

    let templatesData = {};

    async function loadFormData() {
        try {
            const [booksRes, tempsRes] = await Promise.all([
                axios.get('/api/contacts/books'),
                axios.get('/api/templates')
            ]);

            const books = booksRes.data.books || [];
            const templates = tempsRes.data.templates || [];

            const bookSelect = document.getElementById('campBook');
            bookSelect.innerHTML = '<option value="" disabled selected>Select target book...</option>' +
                books.map(b => `<option value="${b.id}">${b.name}</option>`).join('');

            const tempSelect = document.getElementById('campTemplate');
            // Store templates for lookup to avoid btoa/Unicode issues
            templatesData = {};
            templates.forEach(t => {
                templatesData[t.token] = t.content;
            });

            tempSelect.innerHTML = '<option value="">Manual Entry (type below)</option>' +
                templates.map(t => `<option value="${t.token}">${t.name}</option>`).join('');

            tempSelect.onchange = (e) => {
                if (e.target.value) {
                    const content = templatesData[e.target.value] || '';
                    document.getElementById('campMessage').value = content;
                }
            };
        } catch (err) {
            console.error('Failed to load form data:', err);
            showToast.error('Failed to load templates or books');
        }
    }

    function openCampaignModal() {
        loadFormData(); // Refresh data to ensure latest templates and books are visible
        document.getElementById('modal_campaign').showModal();
    }

    function previewImage(input, previewId) {
        const preview = document.getElementById(previewId);
        const img = preview.querySelector('img');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = (e) => {
                img.src = e.target.result;
                preview.classList.remove('hidden');
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function removePreview(inputId, previewId) {
        document.getElementById(inputId).value = '';
        document.getElementById(previewId).classList.add('hidden');
    }

    function toggleTargetType(type) {
        if (type === 'book') {
            $('#target-book-container').removeClass('hidden');
            $('#target-manual-container').addClass('hidden');
        } else {
            $('#target-book-container').addClass('hidden');
            $('#target-manual-container').removeClass('hidden');
        }
    }

    document.getElementById('campaignForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const targetType = $('input[name="targetType"]:checked').val();
        const formData = new FormData();
        formData.append('device_token', document.getElementById('campDevice').value);
        formData.append('name', document.getElementById('campName').value);
        formData.append('message', document.getElementById('campMessage').value);
        formData.append('min_delay', document.getElementById('campMinDelay').value);
        formData.append('max_delay', document.getElementById('campMaxDelay').value);

        if (targetType === 'book') {
            formData.append('book_id', document.getElementById('campBook').value);
        } else {
            formData.append('receivers', document.getElementById('campReceivers').value);
        }

        const fileInput = document.getElementById('campFile');
        if (fileInput.files.length > 0) {
            formData.append('file', fileInput.files[0]);
        }

        try {
            const res = await axios.post('/api/campaigns', formData, {
                headers: { 'Content-Type': 'multipart/form-data' }
            });
            if (res.data.success) {
                document.getElementById('modal_campaign').close();
                showToast.success('Your campaign has been added to queue.', 'Launched!');
                loadCampaigns();
                e.target.reset();
                document.getElementById('campPreview').classList.add('hidden');
            }
        } catch (err) {
            showToast.error(err.response?.data?.message || 'Failed to start campaign', 'Error');
        }
    });

    async function deleteCampaign(token) {
        const result = await showConfirm(
            'Delete Campaign?',
            'This will permanently delete this campaign record.',
            'Yes, delete it!',
            'Cancel'
        );

        if (!result.isConfirmed) return;

        try {
            await axios.delete(`/api/campaigns/${token}`);
            showToast.success('Campaign has been deleted.', 'Deleted!');
            loadCampaigns();
        } catch (err) {
            showToast.error(err.response?.data?.message || 'Failed to delete', 'Error');
        }
    }

    document.addEventListener('DOMContentLoaded', initCampaigns);
</script>

