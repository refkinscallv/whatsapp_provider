<!-- Reusable Contacts Modal -->
<dialog id="modal_contacts" class="modal">
    <div class="modal-box bg-base-100 border border-base-content/5 max-w-4xl max-h-[80vh] flex flex-col">
        <div class="flex justify-between items-center mb-6">
            <h3 class="font-bold text-lg text-base-content">Select from Contacts</h3>
            <form method="dialog"><button class="btn btn-ghost btn-sm btn-circle">✕</button></form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 flex-1 overflow-hidden">
            <!-- Book List -->
            <div class="space-y-2 overflow-y-auto pr-2 border-r border-base-content/5">
                <p class="text-[10px] uppercase font-bold text-base-content/40 mb-3 px-2">Contact Books</p>
                <div id="book-list-picker" class="space-y-1">
                    <p class="text-xs opacity-40 text-center py-10">Loading...</p>
                </div>
            </div>

            <!-- Contact List -->
            <div class="md:col-span-2 flex flex-col overflow-hidden">
                <div class="flex gap-2 mb-4">
                    <div class="relative flex-1">
                        <i class="ri-search-line absolute left-3 top-1/2 -translate-y-1/2 opacity-30"></i>
                        <input type="text" id="contact-search" placeholder="Search contacts..."
                            class="input input-bordered input-sm w-full pl-9 rounded-xl">
                    </div>
                    <button onclick="toggleAllContacts()" class="btn btn-ghost btn-sm text-primary">Toggle All</button>
                </div>

                <div id="contact-list-picker" class="flex-1 overflow-y-auto space-y-1 pr-2">
                    <p class="text-xs opacity-20 text-center py-20 italic">Select a book to view contacts</p>
                </div>
            </div>
        </div>

        <div class="modal-action mt-6 border-t border-base-content/5 pt-4">
            <div class="flex-1 text-xs text-base-content/40 flex items-center">
                <span id="selected-count">0</span> contacts selected
            </div>
            <form method="dialog"><button class="btn btn-ghost">Cancel</button></form>
            <button onclick="applyContactSelection()" class="btn btn-primary rounded-xl px-10">Import Selected</button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>
<script src="/js/contact-selector.js"></script>