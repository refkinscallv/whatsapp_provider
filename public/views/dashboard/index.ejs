<div class="flex flex-col gap-10">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-4xl font-black text-base-content tracking-tighter">Dashboard <span
                    class="text-primary">Overview</span></h1>
            <p class="text-base-content/50 mt-1">Welcome back! Here's your real-time automation status.</p>
        </div>
        <div class="flex gap-3">
            <button onclick="refreshStats()" class="btn btn-ghost glass rounded-2xl px-6"><i
                    class="ri-refresh-line"></i> Sync Data</button>
            <a href="/devices" class="btn btn-primary rounded-2xl px-6 shadow-lg shadow-primary/20"><i
                    class="ri-add-line"></i> Connect Device</a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card glass hover:border-primary/30 transition-all duration-300 group">
            <div class="card-body p-8">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Total Devices
                        </p>
                        <h2 class="text-4xl font-black mt-2 text-base-content" id="stat-devices">0</h2>
                    </div>
                    <div
                        class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                        <i class="ri-smartphone-line text-2xl"></i>
                    </div>
                </div>
                <div class="mt-6 flex flex-col gap-2">
                    <div class="flex justify-between items-center text-[10px] uppercase font-bold text-base-content/40">
                        <span>Utilization</span>
                        <span id="limit-devices-text">0/0</span>
                    </div>
                    <div class="w-full bg-base-content/5 h-1.5 rounded-full overflow-hidden">
                        <div id="bar-devices" class="bg-primary h-full rounded-full transition-all duration-1000"
                            style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card glass hover:border-success/30 transition-all duration-300 group">
            <div class="card-body p-8">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Messages (30d)
                        </p>
                        <h2 class="text-4xl font-black mt-2 text-base-content" id="stat-messages">0</h2>
                    </div>
                    <div
                        class="w-14 h-14 bg-success/10 rounded-2xl flex items-center justify-center text-success group-hover:scale-110 transition-transform">
                        <i class="ri-chat-check-line text-2xl"></i>
                    </div>
                </div>
                <div class="mt-6 flex items-center justify-between">
                    <div class="flex flex-col">
                        <span
                            class="text-[10px] font-black uppercase text-base-content/30 tracking-widest">Success</span>
                        <span id="stat-success" class="text-success font-bold">0</span>
                    </div>
                    <div class="flex flex-col items-end">
                        <span
                            class="text-[10px] font-black uppercase text-base-content/30 tracking-widest">Failed</span>
                        <span id="stat-failed" class="text-error font-bold">0</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card glass hover:border-warning/30 transition-all duration-300 group">
            <div class="card-body p-8">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Active
                            Campaigns</p>
                        <h2 class="text-4xl font-black mt-2 text-base-content" id="stat-campaigns">0</h2>
                    </div>
                    <div
                        class="w-14 h-14 bg-warning/10 rounded-2xl flex items-center justify-center text-warning group-hover:scale-110 transition-transform">
                        <i class="ri-broadcast-line text-2xl"></i>
                    </div>
                </div>
                <div class="mt-6 flex items-center gap-2">
                    <span class="badge badge-warning badge-sm rounded px-3">Running Now</span>
                </div>
            </div>
        </div>

        <div class="card glass hover:border-secondary/30 transition-all duration-300 group">
            <div class="card-body p-8">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Quota Left</p>
                        <h2 class="text-4xl font-black mt-2 text-base-content" id="stat-quota">0</h2>
                    </div>
                    <div
                        class="w-14 h-14 bg-secondary/10 rounded-2xl flex items-center justify-center text-secondary group-hover:scale-110 transition-transform">
                        <i class="ri-database-2-line text-2xl"></i>
                    </div>
                </div>
                <div class="mt-6 flex flex-col gap-2">
                    <div class="flex justify-between items-center text-[10px] uppercase font-bold text-base-content/40">
                        <span>Remaining</span>
                        <span id="quota-percent">100%</span>
                    </div>
                    <div class="w-full bg-base-content/5 h-1.5 rounded-full overflow-hidden">
                        <div id="bar-quota" class="bg-secondary h-full rounded-full transition-all duration-1000"
                            style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Recent Messages -->
        <div class="lg:col-span-2 card glass">
            <div class="card-body p-0">
                <div class="p-8 flex items-center justify-between">
                    <h3 class="font-black text-xl tracking-tight">Recent <span class="text-primary">Activities</span>
                    </h3>
                    <a href="/history" class="btn btn-ghost btn-sm rounded-xl">View History <i
                            class="ri-arrow-right-s-line"></i></a>
                </div>
                <div class="overflow-x-auto p-4">
                    <table id="dashboard-recent-table" class="table table-lg w-full">
                        <thead class="bg-base-content/5 rounded-2xl overflow-hidden">
                            <tr
                                class="text-base-content/50 uppercase text-[10px] font-black tracking-[0.2em] border-none">
                                <th class="rounded-l-2xl">Recipient</th>
                                <th>Content</th>
                                <th>Status</th>
                                <th class="rounded-r-2xl text-right">Timestamp</th>
                            </tr>
                        </thead>
                        <tbody id="table-recent" class="border-none">
                            <tr>
                                <td colspan="4" class="text-center py-20">
                                    <span class="loading loading-spinner loading-lg text-primary"></span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- System Info -->
        <div class="card glass overflow-hidden">
            <div class="card-body p-0">
                <div class="p-8">
                    <h3 class="font-black text-xl tracking-tight">System Status</h3>
                </div>

                <div class="p-8 space-y-8">
                    <div
                        class="relative p-6 rounded-[2rem] bg-gradient-to-br from-primary/20 to-secondary/20 border border-primary/20 overflow-hidden group">
                        <div
                            class="absolute -top-10 -right-10 w-32 h-32 bg-primary/20 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-700">
                        </div>
                        <div class="relative z-10 flex items-center justify-between gap-2">
                            <div class="flex items-center gap-5">
                                <div
                                    class="w-14 h-14 bg-primary text-primary-content rounded-2xl flex items-center justify-center text-2xl shadow-xl shadow-primary/30">
                                    <i class="ri-vip-diamond-fill"></i>
                                </div>
                                <div>
                                    <h4 class="font-black text-xl text-base-content" id="plan-name">-</h4>
                                    <p class="text-xs font-bold text-base-content/40 tracking-wider uppercase mt-1"
                                        id="plan-expiry">Valid: ---</p>
                                </div>
                            </div>
                            <% if (isSubscriptionEnabled) { %>
                                <a href="/billing"
                                    class="btn btn-primary btn-sm rounded-xl px-4 shadow-lg shadow-primary/20">Upgrade</a>
                                <% } %>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div
                            class="flex items-center justify-between p-4 rounded-2xl bg-base-content/5 border border-transparent hover:border-success/20 transition-all">
                            <div class="flex items-center gap-3">
                                <div class="w-2 h-2 rounded-full bg-success"></div>
                                <span class="text-sm font-bold opacity-70">WWeb Service</span>
                            </div>
                            <span class="badge badge-success badge-outline font-black text-[10px]">OPERATIONAL</span>
                        </div>
                        <div
                            class="flex items-center justify-between p-4 rounded-2xl bg-base-content/5 border border-transparent hover:border-success/20 transition-all">
                            <div class="flex items-center gap-3">
                                <div class="w-2 h-2 rounded-full bg-success animate-pulse"></div>
                                <span class="text-sm font-bold opacity-70">API Gateway</span>
                            </div>
                            <span class="badge badge-success badge-outline font-black text-[10px]">ACTIVE</span>
                        </div>
                    </div>

                    <a href="https://wa.me/62895392168277"
                        class="btn btn-outline btn-block rounded-2xl h-14 border-base-content/10 group">
                        <i class="ri-customer-service-2-line text-lg"></i> Contact Support
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let recentDataTable = null;

    async function loadStats() {
        try {
            const res = await axios.get('/api/dashboard');
            if (res.data.success) {
                const { stats, recent } = res.data;

                // Update stats
                $('#stat-devices').text(stats.devices.total);
                $('#limit-devices-text').text(stats.devices.total + ' / ' + stats.devices.limit);

                const deviceUsage = stats.devices.limit === '∞' ? 0 : (stats.devices.total / stats.devices.limit * 100);
                $('#bar-devices').css('width', Math.min(deviceUsage, 100) + '%');

                $('#stat-messages').text(stats.messages.total_30d.toLocaleString());
                $('#stat-success').text(stats.messages.success_30d.toLocaleString());
                $('#stat-failed').text(stats.messages.failed_30d.toLocaleString());

                $('#stat-campaigns').text(stats.campaigns.active);

                $('#stat-quota').text(stats.messages.remaining.toLocaleString());
                const quotaTotal = stats.messages.limit === '∞' ? 0 : stats.messages.limit;
                const quotaPercent = quotaTotal === 0 ? 100 : (stats.messages.remaining / quotaTotal * 100);
                $('#quota-percent').text(Math.round(quotaPercent) + '%');
                $('#bar-quota').css('width', Math.min(quotaPercent, 100) + '%');

                if (stats.subscription) {
                    $('#plan-name').text(stats.subscription.package_name || 'Standard Plan');
                    const expiry = stats.subscription.ends_at ? new Date(stats.subscription.ends_at).toLocaleDateString() : 'Never';
                    $('#plan-expiry').text('Valid: ' + expiry);
                } else {
                    $('#plan-name').text(window.isSubscriptionEnabled ? 'Free Plan' : 'Self-Hosted');
                    $('#plan-expiry').text(window.isSubscriptionEnabled ? 'Upgrade to Unlock More' : 'Unlimited Access');
                }

                // Update table
                const table = $('#table-recent');

                if (recentDataTable) recentDataTable.destroy();

                if (recent.length === 0) {
                    table.html('<tr><td colspan="4" class="text-center py-20 text-base-content/30 italic">No recent activities found</td></tr>');
                } else {
                    table.html(recent.map(msg => `
                        <tr class="hover:bg-base-content/5 transition-all group border-none">
                            <td class="rounded-l-2xl">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-base-content/5 rounded-xl flex items-center justify-center text-primary">
                                        <i class="ri-user-follow-line"></i>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-sm text-base-content">${msg.to}</span>
                                        <span class="text-[10px] uppercase font-black opacity-30 tracking-widest">${msg.type}</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <p class="text-sm text-base-content/70 max-w-[240px] truncate group-hover:text-base-content transition-colors font-medium">
                                    ${msg.message}
                                </p>
                            </td>
                            <td data-message-id="${msg.message_id}">
                                <div class="badge ${msg.status === 'sent' || msg.status === 'delivered' || msg.status === 'read' ? 'badge-success' : 'badge-error'} badge-sm rounded-lg py-3 px-4 font-black text-[9px] uppercase tracking-widest border-none shadow-sm status-badge">
                                    ${msg.status}
                                </div>
                            </td>
                            <td class="rounded-r-2xl text-right">
                                <span class="text-xs font-bold text-base-content/30">${new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
                            </td>
                        </tr>
                    `).join(''));

                    recentDataTable = $('#dashboard-recent-table').DataTable({
                        paging: false,
                        searching: false,
                        info: false,
                        order: [[3, 'desc']],
                        columnDefs: [
                            { orderable: false, targets: [0, 1, 2] }
                        ]
                    });
                }
            }
        } catch (err) {
            console.error('Failed to load stats', err);
        }
    }

    function refreshStats() {
        showToast.loading('Refreshing data...');
        loadStats().then(() => showToast.close());
    }

    // Socket.io Real-time Updates
    const socket = io({
        query: { userToken: '<%= userToken %>' }
    });

    socket.on('user:status', (stats) => {
        if (stats.devices) {
            $('#stat-devices').text(stats.devices.total);

            // Handle limit for display
            let limitText = $('#limit-devices-text').text().split('/')[1]?.trim() || '0';
            const isAdmin = '<%= req.user?.role %>' === 'SUPER_ADMIN';

            if (isAdmin) limitText = '∞';

            $('#limit-devices-text').text(stats.devices.total + ' / ' + limitText);

            const deviceLimit = limitText === '∞' ? 0 : (parseInt(limitText) || 0);
            const usage = deviceLimit === 0 ? 0 : (stats.devices.total / deviceLimit * 100);
            $('#bar-devices').css('width', Math.min(usage, 100) + '%');
        }

        if (stats.messages) {
            // Stats today could be different from stats 30d, but for real-time feel we update what we can
            // In this UI, stat-messages is 30d, so we don't overwrite it with daily unless we change the UI
            // But we can update Quota Left real-time
            if (stats.messages.remaining !== undefined) {
                $('#stat-quota').text(stats.messages.remaining.toLocaleString());
            }
        }
    });

    socket.on('whatsapp:ready', () => loadStats());
    socket.on('whatsapp:disconnected', () => loadStats());
    socket.on('queue:update', () => loadStats());

    socket.on('message:ack', (data) => {
        const { messageId, ackName } = data;
        const cell = $(`td[data-message-id="${messageId}"]`);
        if (cell.length) {
            const badge = cell.find('.status-badge');
            badge.text(ackName);

            // Update colors
            if (['sent', 'delivered', 'read'].includes(ackName)) {
                badge.removeClass('badge-error badge-warning').addClass('badge-success');
            } else if (ackName === 'failed') {
                badge.removeClass('badge-success badge-warning').addClass('badge-error');
            }
        }
    });

    $(document).ready(loadStats);
</script>