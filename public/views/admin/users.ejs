<div class="space-y-8">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-base-content">User Management</h1>
            <p class="text-base-content/60">View and manage all registered accounts.</p>
        </div>
        <div class="flex gap-2">
            <button onclick="DataTableHelper.openFilterModal('filter_modal_users', 'users-table')"
                class="btn btn-primary btn-sm rounded-lg"><i class="ri-filter-3-line"></i> Filter</button>
            <button onclick="openAddUserModal()" class="btn btn-primary btn-sm rounded-lg"><i
                    class="ri-user-add-line"></i> New User</button>
            <a href="/admin" class="btn btn-ghost btn-sm rounded-lg"><i class="ri-arrow-left-line"></i> Back to
                Dashboard</a>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="card glass hover:border-primary/30 transition-all duration-300 group">
            <div class="card-body p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Total Users
                        </p>
                        <h2 class="text-3xl font-black mt-1 text-base-content" id="stat-total">0</h2>
                    </div>
                    <div
                        class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                        <i class="ri-group-line text-xl"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="card glass hover:border-success/30 transition-all duration-300 group">
            <div class="card-body p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Active</p>
                        <h2 class="text-3xl font-black mt-1 text-success" id="stat-active">0</h2>
                    </div>
                    <div
                        class="w-12 h-12 bg-success/10 rounded-xl flex items-center justify-center text-success group-hover:scale-110 transition-transform">
                        <i class="ri-user-follow-line text-xl"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="card glass hover:border-error/30 transition-all duration-300 group">
            <div class="card-body p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Inactive</p>
                        <h2 class="text-3xl font-black mt-1 text-error" id="stat-inactive">0</h2>
                    </div>
                    <div
                        class="w-12 h-12 bg-error/10 rounded-xl flex items-center justify-center text-error group-hover:scale-110 transition-transform">
                        <i class="ri-user-forbid-line text-xl"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="card glass hover:border-accent/30 transition-all duration-300 group">
            <div class="card-body p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-base-content/40">Super Admin
                        </p>
                        <h2 class="text-3xl font-black mt-1 text-accent" id="stat-admin">0</h2>
                    </div>
                    <div
                        class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center text-accent group-hover:scale-110 transition-transform">
                        <i class="ri-shield-user-line text-xl"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card glass shadow-sm overflow-hidden">
        <div class="overflow-x-auto p-4">
            <table id="users-table" class="table table-lg w-full">
                <thead>
                    <tr
                        class="text-base-content/60 uppercase text-[10px] tracking-widest border-b-2 border-base-content/5">
                        <th>User</th>
                        <th>WhatsApp</th>
                        <th>Type</th>
                        <th>Joined</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Data loaded via server-side DataTables -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Filter Modal -->
<dialog id="filter_modal_users" class="modal">
    <div class="modal-box bg-base-100 border border-base-content/5 rounded-3xl max-w-md p-0 overflow-hidden">
        <div class="p-6 border-b border-base-content/5">
            <h3 class="font-bold text-xl text-base-content flex items-center gap-2">
                <i class="ri-filter-3-line text-primary"></i> Filter Users
            </h3>
        </div>

        <form id="filter_form_users" class="p-6 space-y-6">
            <!-- User Type Filter -->
            <div class="form-control">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">User
                    Type</label>
                <select name="user_type" class="select select-bordered w-full rounded-2xl bg-base-200/50">
                    <option value="">All Types</option>
                    <option value="PERSONAL">Personal</option>
                    <option value="COMPANY">Company</option>
                </select>
            </div>

            <!-- Status Filter -->
            <div class="form-control">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Status</label>
                <select name="status" class="select select-bordered w-full rounded-2xl bg-base-200/50">
                    <option value="">All Status</option>
                    <option value="ACTIVE">Active</option>
                    <option value="INACTIVE">Inactive</option>
                    <option value="UNVERIFIED">Unverified</option>
                </select>
            </div>

            <!-- Role Filter -->
            <div class="form-control">
                <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Role</label>
                <select name="role" class="select select-bordered w-full rounded-2xl bg-base-200/50">
                    <option value="">All Roles</option>
                    <option value="MEMBER">Member</option>
                    <option value="SUPER_ADMIN">Super Admin</option>
                </select>
            </div>

            <!-- Date Range -->
            <div class="grid grid-cols-2 gap-4">
                <div class="form-control">
                    <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">From
                        Date</label>
                    <input type="date" name="created_from"
                        class="input input-bordered w-full rounded-2xl bg-base-200/50">
                </div>
                <div class="form-control">
                    <label class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">To
                        Date</label>
                    <input type="date" name="created_to" class="input input-bordered w-full rounded-2xl bg-base-200/50">
                </div>
            </div>
        </form>

        <div class="modal-action p-6 border-t border-base-content/5 mt-0">
            <button type="button"
                onclick="DataTableHelper.resetFilters('filter_form_users', 'users-table', 'filter_modal_users')"
                class="btn btn-ghost rounded-xl">
                <i class="ri-restart-line"></i> Reset
            </button>
            <button type="button" onclick="DataTableHelper.applyFilters('users-table', 'filter_modal_users')"
                class="btn btn-primary rounded-xl px-8">
                <i class="ri-check-line"></i> Apply Filter
            </button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>


<!-- Edit/Create User Modal -->
<dialog id="edit_user_modal" class="modal">
    <div
        class="modal-box w-11/12 max-w-4xl bg-base-100 border border-base-content/5 text-base-content rounded-3xl p-0 overflow-hidden">
        <form method="dialog">
            <button class="btn btn-sm btn-circle btn-ghost absolute right-4 top-4 z-10">✕</button>
        </form>
        <div class="p-8 space-y-8">
            <div>
                <h3 class="font-bold text-2xl" id="modal-title">Edit User</h3>
                <p class="text-sm opacity-60" id="modal-subtitle">Update account details, subscription, and usage
                    limits.</p>
            </div>

            <form id="editUserForm" class="space-y-8">
                <input type="hidden" id="edit_token">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- Column 1: Account Info -->
                    <div class="space-y-6">
                        <div
                            class="badge badge-outline badge-lg w-full py-4 font-bold tracking-widest text-[10px] uppercase opacity-50">
                            Account Information</div>
                        <div class="form-control">
                            <label
                                class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Full
                                Name</label>
                            <input type="text" id="edit_name" class="input input-bordered w-full rounded-2xl" required>
                        </div>
                        <div class="form-control">
                            <label
                                class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Email
                                Address</label>
                            <input type="email" id="edit_email" class="input input-bordered w-full rounded-2xl"
                                required>
                        </div>
                        <div class="form-control" id="password-field">
                            <label
                                class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Password</label>
                            <input type="password" id="edit_password" class="input input-bordered w-full rounded-2xl">
                        </div>
                        <div class="form-control">
                            <label
                                class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">WhatsApp
                                Number</label>
                            <input type="text" id="edit_whatsapp" class="input input-bordered w-full rounded-2xl"
                                required>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="form-control">
                                <label
                                    class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">User
                                    Type</label>
                                <select id="edit_user_type" class="select select-bordered w-full rounded-2xl">
                                    <option value="PERSONAL">PERSONAL</option>
                                    <option value="COMPANY">COMPANY</option>
                                </select>
                            </div>
                            <div class="form-control">
                                <label
                                    class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Status</label>
                                <select id="edit_status" class="select select-bordered w-full rounded-2xl">
                                    <option value="ACTIVE">ACTIVE</option>
                                    <option value="INACTIVE">INACTIVE</option>
                                    <option value="UNVERIFIED">UNVERIFIED</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-control">
                            <label
                                class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Role</label>
                            <select id="edit_role" class="select select-bordered w-full rounded-2xl">
                                <option value="MEMBER">MEMBER</option>
                                <option value="SUPER_ADMIN">SUPER_ADMIN</option>
                            </select>
                        </div>
                    </div>

                    <!-- Column 2: Subscription & Usage -->
                    <div class="space-y-6">
                        <div
                            class="badge badge-outline badge-lg w-full py-4 font-bold tracking-widest text-[10px] uppercase opacity-50">
                            Subscription & Usage</div>
                        <div class="form-control">
                            <label
                                class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Active
                                Package</label>
                            <select id="edit_package" class="select select-bordered w-full rounded-2xl">
                                <option value="">No Active Subscription</option>
                                <!-- Packages will be populated here -->
                            </select>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="form-control">
                                <label
                                    class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Started
                                    At</label>
                                <input type="date" id="edit_started_at"
                                    class="input input-bordered w-full rounded-2xl font-bold">
                            </div>
                            <div class="form-control">
                                <label
                                    class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Expired
                                    At</label>
                                <input type="date" id="edit_expired_at"
                                    class="input input-bordered w-full rounded-2xl font-bold">
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="form-control">
                                <label
                                    class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Limit
                                    Device</label>
                                <input type="number" id="edit_limit_device"
                                    class="input input-bordered w-full rounded-2xl font-bold">
                            </div>
                            <div class="form-control">
                                <label
                                    class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Limit
                                    API Key</label>
                                <input type="number" id="edit_limit_api_key"
                                    class="input input-bordered w-full rounded-2xl font-bold">
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="form-control">
                                <label
                                    class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Limit
                                    Domain</label>
                                <input type="number" id="edit_limit_domain"
                                    class="input input-bordered w-full rounded-2xl font-bold">
                            </div>
                            <div class="form-control">
                                <label
                                    class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Limit
                                    Message</label>
                                <input type="number" id="edit_limit_message"
                                    class="input input-bordered w-full rounded-2xl font-bold">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-action px-8 pb-8">
                    <button type="button" onclick="edit_user_modal.close()"
                        class="btn btn-ghost rounded-xl">Cancel</button>
                    <button type="submit" class="btn btn-primary px-10 rounded-xl" id="btn-save-user">Save
                        Changes</button>
                </div>
            </form>
        </div>
    </div>
</dialog>

<script>
    let usersDataTable = null;
    const currentUserToken = '<%= user.token %>';

    $(document).ready(function () {
        initPage();
    });

    async function initPage() {
        await loadStats();
        initUsersDataTable();
    }

    async function loadStats() {
        try {
            const res = await axios.get('/api/admin/users/stats');
            if (res.data.success) {
                const s = res.data.stats;
                $('#stat-total').text(s.total || 0);
                $('#stat-active').text(s.active || 0);
                $('#stat-inactive').text(s.inactive || 0);
                $('#stat-admin').text(s.super_admin || 0);
            }
        } catch (err) {
            console.error('Error loading user stats:', err);
        }
    }

    function initUsersDataTable() {
        // Initialize server-side DataTable
        const columns = [
            {
                data: 'name',
                render: function (data, type, row) {
                    const initial = (row.name || 'U').charAt(0).toUpperCase();
                    return `
                        <div class="flex items-center gap-3">
                            <div class="avatar avatar-placeholder">
                                <div class="bg-neutral text-neutral-content w-10 rounded-full">
                                    <span class="text-2xl">${initial}</span>
                                </div>
                            </div>
                            <div>
                                <div class="font-bold text-base-content">${row.name}</div>
                                <div class="text-xs text-base-content/50">${row.email}</div>
                            </div>
                        </div>
                    `;
                }
            },
            {
                data: 'whatsapp',
                render: function (data) {
                    return `<span class="font-mono text-xs text-base-content">${data}</span>`;
                }
            },
            {
                data: 'user_type',
                render: function (data) {
                    return `<span class="badge badge-outline badge-sm rounded-lg py-3 px-4 font-bold tracking-widest text-[10px] uppercase">${data}</span>`;
                }
            },
            {
                data: 'createdAt',
                render: function (data, type, row) {
                    const statusColor = row.status === 'ACTIVE' ? 'bg-success' : 'bg-error';
                    const date = new Date(row.createdAt).toLocaleDateString();
                    return `
                        <div class="flex flex-col">
                            <div class="flex items-center gap-2">
                                <div class="w-1.5 h-1.5 rounded-full ${statusColor}"></div>
                                <span class="text-xs font-bold tracking-widest text-base-content/50 uppercase">${row.status}</span>
                            </div>
                            <div class="text-[10px] opacity-40 mt-1">${date}</div>
                        </div>
                    `;
                }
            },
            {
                data: null,
                orderable: false,
                render: function (data, type, row) {
                    if (row.token === currentUserToken) {
                        return `<div class="text-right"><span class="badge badge-ghost badge-sm italic opacity-50">You</span></div>`;
                    }

                    const blockIcon = row.status === 'ACTIVE' ? 'ri-user-unfollow-line' : 'ri-user-follow-line';
                    const blockColor = row.status === 'ACTIVE' ? 'text-warning' : 'text-success';
                    const blockTitle = row.status === 'ACTIVE' ? 'Block' : 'Unblock';

                    return `
                        <div class="flex justify-end gap-1">
                            <button onclick="editUser('${row.token}')" class="btn btn-ghost btn-xs text-primary" title="Edit">
                                <i class="ri-edit-line"></i>
                            </button>
                            <button onclick="toggleUserStatus('${row.token}', '${row.status}')" 
                                class="btn btn-ghost btn-xs ${blockColor}" title="${blockTitle}">
                                <i class="${blockIcon}"></i>
                            </button>
                            <button onclick="deleteUser('${row.token}')" class="btn btn-ghost btn-xs text-error" title="Delete">
                                <i class="ri-delete-bin-line"></i>
                            </button>
                        </div>
                    `;
                }
            }
        ];

        usersDataTable = DataTableHelper.initServerSideDataTable(
            'users-table',
            '/api/admin/datatable/users',
            columns,
            {
                order: [[3, 'desc']], // Order by joined date descending
                pageLength: 25
            }
        );
    };

    async function toggleUserStatus(token, currentStatus) {
        const newStatus = currentStatus === 'ACTIVE' ? 'BLOCKED' : 'ACTIVE';
        const confirm = await showConfirm(
            `${newStatus === 'BLOCKED' ? 'Block' : 'Unblock'} User?`,
            `This user will ${newStatus === 'BLOCKED' ? 'lose' : 'regain'} access to the system.`,
            `Yes, ${newStatus === 'BLOCKED' ? 'block' : 'unblock'}`,
            'Cancel'
        );

        if (confirm.isConfirmed) {
            try {
                await axios.put(`/api/admin/users/${token}/status`, { status: newStatus });
                DataTableHelper.reloadTable('users-table');
                showToast.success('User status updated', 'Success');
            } catch (err) {
                showToast.error('Update failed', 'Error');
            }
        }
    }

    async function deleteUser(token) {
        const confirm = await showConfirm(
            'Delete User?',
            'All user data, devices, and history will be permanently removed.',
            'Yes, delete',
            'Cancel'
        );

        if (confirm.isConfirmed) {
            try {
                await axios.delete(`/api/admin/users/${token}`);
                DataTableHelper.reloadTable('users-table');
                showToast.success('User deleted successfully', 'Success');
            } catch (err) {
                showToast.error('Delete failed', 'Error');
            }
        }
    }

    async function openAddUserModal() {
        $('#modal-title').text('New User');
        $('#modal-subtitle').text('Create a new account with an initial subscription.');
        $('#btn-save-user').text('Create User');
        $('#edit_token').val('');
        $('#password-field').show();
        $('#edit_password').attr('required', true);
        $('#editUserForm')[0].reset();

        // Populate packages if possible (fetch from stats)
        try {
            const res = await axios.get('/api/admin/users/stats');
            const pkgSelect = $('#edit_package');
            pkgSelect.empty();
            pkgSelect.append('<option value="">No Active Subscription</option>');
            if (res.data.success && res.data.packages) {
                res.data.packages.forEach(pkg => {
                    pkgSelect.append(`<option value="${pkg.token}">${pkg.name}</option>`);
                });
            }
        } catch (e) { }

        edit_user_modal.showModal();
    }

    async function editUser(token) {
        try {
            const res = await axios.get(`/api/admin/users/${token}`);
            if (res.data.success) {
                const { user, packages } = res.data;

                $('#modal-title').text('Edit User');
                $('#modal-subtitle').text('Update account details, subscription, and usage limits.');
                $('#btn-save-user').text('Save Changes');
                $('#password-field').hide();
                $('#edit_password').attr('required', false);

                // Populate Packages Dropdown
                const pkgSelect = $('#edit_package');
                pkgSelect.empty();
                pkgSelect.append('<option value="">No Active Subscription</option>');
                packages.forEach(pkg => {
                    pkgSelect.append(`<option value="${pkg.token}">${pkg.name}</option>`);
                });

                // Set User Fields
                $('#edit_token').val(user.token);
                $('#edit_name').val(user.name);
                $('#edit_email').val(user.email);
                $('#edit_whatsapp').val(user.whatsapp);
                $('#edit_user_type').val(user.user_type);
                $('#edit_status').val(user.status);
                $('#edit_role').val(user.role);

                // Set Subscription & Usage
                const sub = user.subscriptions && user.subscriptions.find(s => s.status === 'ACTIVE');
                if (sub) {
                    $('#edit_package').val(sub.package_token);
                    $('#edit_started_at').val(new Date(sub.started_at).toISOString().split('T')[0]);
                    $('#edit_expired_at').val(new Date(sub.expired_at).toISOString().split('T')[0]);

                    if (sub.usage) {
                        $('#edit_limit_device').val(sub.usage.remaining_device);
                        $('#edit_limit_api_key').val(sub.usage.remaining_api_key);
                        $('#edit_limit_domain').val(sub.usage.remaining_domain);
                        $('#edit_limit_message').val(sub.usage.remaining_message);
                    }
                } else {
                    $('#edit_package').val('');
                    $('#edit_started_at').val('');
                    $('#edit_expired_at').val('');
                    $('#edit_limit_device').val('');
                    $('#edit_limit_api_key').val('');
                    $('#edit_limit_domain').val('');
                    $('#edit_limit_message').val('');
                }

                edit_user_modal.showModal();
            }
        } catch (err) {
            showToast.error('Failed to fetch user data', 'Error');
        }
    }

    $('#editUserForm').on('submit', async function (e) {
        e.preventDefault();
        const token = $('#edit_token').val();
        const isCreate = !token;

        const data = {
            user: {
                name: $('#edit_name').val(),
                email: $('#edit_email').val(),
                whatsapp: $('#edit_whatsapp').val(),
                user_type: $('#edit_user_type').val(),
                status: $('#edit_status').val(),
                role: $('#edit_role').val()
            },
            subscription: {
                package_token: $('#edit_package').val(),
                started_at: $('#edit_started_at').val(),
                expired_at: $('#edit_expired_at').val()
            },
            usage: {
                remaining_device: $('#edit_limit_device').val(),
                remaining_api_key: $('#edit_limit_api_key').val(),
                remaining_domain: $('#edit_limit_domain').val(),
                remaining_message: $('#edit_limit_message').val()
            }
        };

        if (isCreate) {
            data.user.password = $('#edit_password').val();
        }

        try {
            if (isCreate) {
                await axios.post('/api/admin/users', data);
            } else {
                await axios.put(`/api/admin/users/${token}`, data);
            }

            edit_user_modal.close();
            showToast.success(isCreate ? 'User created successfully' : 'User updated successfully', 'Success');
            DataTableHelper.reloadTable('users-table');
        } catch (err) {
            showToast.error(err.response?.data?.message || (isCreate ? 'Creation failed' : 'Update failed'), 'Error');
        }
    });
</script>