<div class="max-w-4xl mx-auto py-20 px-4">
    <div class="mb-8">
        <a href="/"
            class="btn btn-ghost btn-sm rounded-full gap-2 text-base-content/60 hover:text-primary transition-all">
            <i class="ri-arrow-left-line"></i>
            <span class="uppercase text-[10px] font-bold tracking-widest">Back to Home</span>
        </a>
    </div>
    <div class="card glass p-10 rounded-3xl">
        <h1 class="text-4xl font-bold text-base-content mb-8 tracking-tighter">Contact Us</h1>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="space-y-6">
                <p class="text-base-content/60">
                    Have questions or need support? Reach out to our team and we'll get back to you
                    as soon as possible.
                </p>
                <div class="flex items-center gap-4 text-base-content">
                    <div
                        class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary text-xl">
                        <i class="ri-whatsapp-line"></i>
                    </div>
                    <div>
                        <p class="text-xs text-base-content/40 uppercase">WhatsApp Support</p>
                        <p class="font-bold">+62 895 3921 68277</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 text-base-content">
                    <div
                        class="w-12 h-12 bg-secondary/10 rounded-xl flex items-center justify-center text-secondary text-xl">
                        <i class="ri-mail-line"></i>
                    </div>
                    <div>
                        <p class="text-xs text-base-content/40 uppercase">Email Support</p>
                        <p class="font-bold">support@warf.com</p>
                    </div>
                </div>
            </div>
            <form class="space-y-4">
                <div class="form-control">
                    <label
                        class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Name</label>
                    <input type="text" placeholder="Your Name" class="input input-bordered w-full rounded-2xl" />
                </div>
                <div class="form-control">
                    <label
                        class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Email</label>
                    <input type="email" placeholder="Your Email" class="input input-bordered w-full rounded-2xl" />
                </div>
                <div class="form-control">
                    <label
                        class="block mb-2 uppercase text-[11px] font-semibold tracking-widest opacity-60">Message</label>
                    <textarea class="textarea textarea-bordered w-full rounded-2xl h-32"
                        placeholder="Your Message"></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-block rounded-xl">Send Message</button>
            </form>
        </div>
    </div>
</div>