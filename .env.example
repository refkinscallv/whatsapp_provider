# Environment Variables Configuration
# Copy this file to .env and update with your values

# Application
NODE_ENV=development
APP_PORT=3025
APP_URL=http://localhost:3025
APP_NAME="WARF"
APP_TIMEZONE=Asia/Jakarta
APP_MODE=SAAS

# Server
SERVER_HTTPS=false
SERVER_SSL_CERT_PATH=
SERVER_SSL_KEY_PATH=

# Database
DB_ENABLED=true
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=whatsapp
DB_USERNAME=root
DB_PASSWORD=
DB_LOGGING=false
DB_TIMEZONE=+07:00
DB_CHARSET=utf8mb4
DB_COLLATE=utf8mb4_general_ci
DB_SYNC=true
DB_FORCE=false
DB_ALTER=false

# JWT
JWT_SECRET=warf_jwt_secret_key_change_this_in_production_2026_whatsapp_api_gateway_secure_token
JWT_EXPIRES_IN=7d

# Mailer (untuk email verification & reset password - implementasi nanti)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME="WARF"
MAIL_FROM_EMAIL=noreply@warf.com

# File Upload
UPLOAD_MAX_SIZE=52428800
UPLOAD_TEMP_DIR=./tmp

# Logging
LOG_DIR=logs

# WhatsApp Configuration
WHATSAPP_SESSIONS_DIR=./whatsapp_sessions
WHATSAPP_CHROME_PATH=
WHATSAPP_WEB_VERSION_CACHE_TYPE=remote
WHATSAPP_QR_MAX_RETRIES=5
WHATSAPP_MAX_RECONNECT_ATTEMPTS=5
WHATSAPP_REINIT_DELAY=5000

# Queue Configuration (Bull/Redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue Settings
QUEUE_FREE_DELAY=5000
QUEUE_PREMIUM_DELAY=0
QUEUE_MAX_ATTEMPTS=3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cron Jobs
CRON_SUBSCRIPTION_EXPIRY=0 0 * * *
CRON_SCHEDULED_MESSAGES=*/1 * * * *
CRON_QUEUE_PROCESSOR=*/30 * * * * *
CRON_CONTACT_SYNC=0 */6 * * *
CRON_CLEANUP=0 2 * * *
